### TC-061: meta.requestId is UUID format
POST {{baseUrl}}{{basePath}}
Authorization: {{token}}
Content-Type: application/json
X-Idempotency-Key: {{$uuid}}

{ "companyCd": "JA07", "companyName": "テスト", "status": "ACTIVE" }

> {%
  client.test("TC-061: meta.requestId UUID format", function() {
    client.assert(response.status === 201, "FAIL: Expected 201, got " + response.status);
    var uuidPattern = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/;
    client.assert(uuidPattern.test(response.body.meta.requestId), "FAIL: requestId must be UUID — got: " + response.body.meta.requestId);
  });
%}

