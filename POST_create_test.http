###


### ─────────────────────────────────────────────────────────────
### SECTION K: MULTIPLE VALIDATION ERRORS (TC-067)
### ─────────────────────────────────────────────────────────────

### TC-067: Multiple validation errors → details[] chứa tất cả
POST {{baseUrl}}{{basePath}}
Authorization: {{token}}
Content-Type: application/json
X-Idempotency-Key: {{$uuid}}

{ "companyCd": null, "companyName": null, "status": null }

> {%
  client.test("TC-067: Multiple errors — all 3 required fields missing", function() {
    client.assert(response.status === 400, "FAIL: Expected 400, got " + response.status + " — multiple invalid fields should return 400");
    client.assert(response.body.error.code === "VALIDATION_ERROR", "FAIL: error.code must be VALIDATION_ERROR — got: " + response.body.error.code);
    var details = response.body.error.details;
    client.assert(details.length >= 3, "FAIL: Must have at least 3 errors, got: " + details.length + " — details: " + JSON.stringify(details));

    var fields = {};
    for (var i = 0; i < details.length; i++) {
      fields[details[i].field] = details[i].message;
    }

    client.assert(fields["companyCd"] !== undefined, "FAIL: Must have companyCd error — present fields: " + Object.keys(fields).join(", "));
    client.assert(fields["companyName"] !== undefined, "FAIL: Must have companyName error — present fields: " + Object.keys(fields).join(", "));
    client.assert(fields["status"] !== undefined, "FAIL: Must have status error — present fields: " + Object.keys(fields).join(", "));

    client.assert(
      fields["companyCd"] === "管理会社コードを入力してください。",
      "FAIL: companyCd JP message wrong — got: " + fields["companyCd"]
    );
    client.assert(
      fields["companyName"] === "管理会社名を入力してください。／管理会社名は30文字以内で入力してください。",
      "FAIL: companyName JP message wrong — got: " + fields["companyName"]
    );
    client.assert(
      fields["status"] === "状態を選択してください。",
      "FAIL: status JP message wrong — got: " + fields["status"]
    );
  });
%}

