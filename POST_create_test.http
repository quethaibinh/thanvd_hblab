### TC-025: companyCd đã tồn tại (active) → 409 H-HMC-VAL-003
### Precondition: TC-001 đã tạo companyCd="TA01"
POST {{baseUrl}}{{basePath}}
Authorization: {{token}}
Content-Type: application/json
X-Idempotency-Key: {{$uuid}}

{ "companyCd": "TA01", "companyName": "重複テスト", "status": "ACTIVE" }

> {%
  client.test("TC-025: Duplicate companyCd — 409 H-HMC-VAL-003", function() {
    client.assert(response.status === 409, "FAIL: Expected 409, got " + response.status + " — duplicate companyCd must be rejected");
    client.assert(response.body.error.code === "CONFLICT", "FAIL: error.code must be CONFLICT — got: " + response.body.error.code);
    var details = response.body.error.details;
    var found = false;
    for (var i = 0; i < details.length; i++) {
      if (details[i].field === "companyCd" && details[i].code === "H-HMC-VAL-003") found = true;
    }
    client.assert(found, "FAIL: Must have H-HMC-VAL-003 — got: " + JSON.stringify(details));
    client.assert(
      response.body.error.message.includes("この管理会社コードは既に登録されています。") ||
      (details.length > 0 && details[0].message === "この管理会社コードは既に登録されています。"),
      "FAIL: Must contain JP message 'この管理会社コードは既に登録されています。' — got: " + JSON.stringify(response.body.error)
    );
  });
%}

