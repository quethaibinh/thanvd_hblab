###

### TC-059: Response structure — tất cả fields hiện diện
POST {{baseUrl}}{{basePath}}
Authorization: {{token}}
Content-Type: application/json
X-Idempotency-Key: {{$uuid}}

{ "companyCd": "JA05", "companyName": "テスト", "status": "ACTIVE" }

> {%
  client.test("TC-059: Response structure — all fields present", function() {
    client.assert(response.status === 201, "FAIL: Expected 201, got " + response.status);
    var d = response.body.data;
    var missing = [];
    var required = ["id", "companyCd", "companyName", "contactPerson", "postalCode", "address", "phone", "fax", "status", "createdBy", "createdAt", "updatedBy", "updatedAt"];
    for (var i = 0; i < required.length; i++) {
      if (d[required[i]] === undefined) missing.push(required[i]);
    }
    client.assert(missing.length === 0, "FAIL: Missing fields: " + missing.join(", ") + " — all fields must be present");
    client.assert(response.body.meta.requestId !== undefined, "FAIL: meta.requestId must exist");
    client.assert(response.body.meta.timestamp !== undefined, "FAIL: meta.timestamp must exist");
    client.assert(response.body.error === null, "FAIL: error must be null on success");
    client.assert(response.body.success === true, "FAIL: success must be true");
  });
%}

