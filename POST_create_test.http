### TC-001: Happy path — tạo mới thành công với đầy đủ fields (201)
POST {{baseUrl}}{{basePath}}
Authorization: {{token}}
Content-Type: application/json
X-Idempotency-Key: {{$uuid}}

{
  "companyCd": "TA01",
  "companyName": "株式会社テスト",
  "contactPerson": "山田太郎",
  "postalCode": "5004008",
  "address": "岐阜県岐阜市",
  "phone": "058-123-4567",
  "fax": "058-123-4568",
  "status": "ACTIVE"
}

> {%
  client.test("TC-001: Happy path — full fields — 201", function() {
    client.assert(response.status === 201, "FAIL: Expected 201, got " + response.status + " — should create with full fields");
    client.assert(response.body.success === true, "FAIL: success must be true — got: " + response.body.success);
    client.assert(response.body.data !== null, "FAIL: data must not be null");
    client.assert(response.body.data.companyCd === "TA01", "FAIL: companyCd must be TA01 — got: " + response.body.data.companyCd);
    client.assert(response.body.data.companyName === "株式会社テスト", "FAIL: companyName mismatch — got: " + response.body.data.companyName);
    client.assert(response.body.data.contactPerson === "山田太郎", "FAIL: contactPerson mismatch — got: " + response.body.data.contactPerson);
    client.assert(response.body.data.postalCode === "5004008", "FAIL: postalCode mismatch — got: " + response.body.data.postalCode);
    client.assert(response.body.data.status === "ACTIVE", "FAIL: status must be ACTIVE — got: " + response.body.data.status);
    client.assert(response.body.data.id !== null, "FAIL: id must be generated — got: " + response.body.data.id);
    client.assert(response.body.error === null, "FAIL: error must be null on success — got: " + JSON.stringify(response.body.error));
    client.assert(response.body.meta.requestId !== undefined, "FAIL: meta.requestId must exist");
  });
  client.log("TC-001 PASS: id=" + response.body.data.id + " updatedAt=" + response.body.data.updatedAt);
%}

