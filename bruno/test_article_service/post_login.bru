meta {
  name: post_login
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "hihi@gmail.com",
    "password": "12345678"
  }
}

script:post-response {
  // Kiểm tra nếu request thành công (status 200 hoặc 201)
  if (res.getStatus() === 200 || res.getStatus() === 201) {
    const data = res.getBody();
    
    // Trích xuất token từ response body (tùy vào cấu trúc JSON của bạn)
    // Ví dụ: { "data": { "token": "abc..." } }
    const token = data.accessToken; 
    
    // Lưu token vào biến môi trường của Bruno
    bru.setEnvVar("access_token", token);
    
    console.log("Đã cập nhật access_token mới thành công!");
  }
}
