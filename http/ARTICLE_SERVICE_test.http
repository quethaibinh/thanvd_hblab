### =============================================================
### ARTICLE SERVICE — Comprehensive Integration Test Suite
### Base URL: http://localhost:8080
### =============================================================

@basePathAuth = /api/auth
@basePathArticles = /api/articles
@basePathProfile = /api/profile

### ─────────────────────────────────────────────────────────────
### SECTION A: AUTHENTICATION (Login, Register & Forgot Password)
### ─────────────────────────────────────────────────────────────

### TC-001: Login thành công (200)
# @name login
POST {{baseUrl}}{{basePathAuth}}/login
Content-Type: application/json

{
  "email": "hihi@gmail.com",
  "password": "12345678"
}

> {%
  client.test("TC-001: Login success — 200", function() {
    client.assert(response.status === 200, "FAIL: Expected 200, got " + response.status);
    client.assert(response.body.accessToken !== undefined, "FAIL: accessToken missing in response");
    client.global.set("auth_token", "Bearer " + response.body.accessToken);
  });
  client.log("Login thành công! Token đã được lưu.");
%}

###

### TC-002: Đăng ký tài khoản mới (200)
POST {{baseUrl}}{{basePathAuth}}/register
Content-Type: application/json

{
  "email": "newuser_{{$randomInt}}@demo.com",
  "password": "password123",
  "fullName": "New User Testing"
}

> {%
  client.test("TC-002: Register success — 200", function() {
    client.assert(response.status === 200, "FAIL: Nên đăng ký thành công");
    client.assert(response.body.accessToken !== undefined, "FAIL: Phải trả về token sau khi đăng ký");
  });
%}

###

### TC-003: Quên mật khẩu (200)
POST {{baseUrl}}{{basePathAuth}}/forgot-password
Content-Type: application/json

{
  "email": "hihi@gmail.com"
}

> {%
  client.test("TC-003: Forgot password — 200", function() {
    client.assert(response.status === 200, "FAIL: Nên trả về 200");
    client.assert(response.body.success === true, "FAIL: Phải trả về success true");
  });
%}

###

### TC-004: Login thất bại — sai mật khẩu (401)
POST {{baseUrl}}{{basePathAuth}}/login
Content-Type: application/json

{
  "email": "hihi@gmail.com",
  "password": "wrong_password"
}

> {%
  client.test("TC-004: Login fail — 401", function() {
    client.assert(response.status === 401, "FAIL: Nên trả về 401 khi sai pass");
  });
%}

###

### ─────────────────────────────────────────────────────────────
### SECTION B: ARTICLES (Query & Management)
### ─────────────────────────────────────────────────────────────

### TC-005: Lấy danh sách bài viết (mặc định — 200)
GET {{baseUrl}}{{basePathArticles}}
Authorization: {{auth_token}}

> {%
  client.test("TC-005: Get articles list default — 200", function() {
    client.assert(response.status === 200, "FAIL: Expected 200");
    client.assert(Array.isArray(response.body.content), "FAIL: content phải là mảng");
    if (response.body.content.length > 0) {
        client.global.set("first_article_id", response.body.content[0].id);
    }
  });
%}

###

### TC-006: Lấy chi tiết một bài viết (200)
GET {{baseUrl}}{{basePathArticles}}/{{first_article_id}}
Authorization: {{auth_token}}

> {%
  client.test("TC-006: Get article detail — 200", function() {
    client.assert(response.status === 200, "FAIL: Article not found");
    client.assert(response.body.id === client.global.get("first_article_id"), "FAIL: ID mismatch");
  });
%}

###

### ─────────────────────────────────────────────────────────────
### SECTION C: INTERACTIONS (Comments & Reactions)
### ─────────────────────────────────────────────────────────────

### TC-007: Thêm bình luận cho bài viết (200)
POST {{baseUrl}}{{basePathArticles}}/{{first_article_id}}/comments
Authorization: {{auth_token}}
Content-Type: application/json

{
  "content": "Bài viết rất hay và bổ ích! (Test comment from HTTP Client)"
}

> {%
  client.test("TC-007: Add comment — 200", function() {
    client.assert(response.status === 200, "FAIL: Phải comment được");
    client.assert(response.body.content.includes("Test comment"), "FAIL: Content mismatch");
  });
%}

###

### TC-008: Thả reaction cho bài viết (200)
POST {{baseUrl}}{{basePathArticles}}/{{first_article_id}}/reactions
Authorization: {{auth_token}}
Content-Type: application/json

{
  "reactionType": "LOVE"
}

> {%
  client.test("TC-008: React to article — 200", function() {
    client.assert(response.status === 200, "FAIL: Phải react được");
    client.assert(response.body.userReaction === "LOVE", "FAIL: Reaction mismatch");
  });
%}

###

### ─────────────────────────────────────────────────────────────
### SECTION D: USER PROFILE
### ─────────────────────────────────────────────────────────────

### TC-009: Lấy thông tin cá nhân (200)
GET {{baseUrl}}{{basePathProfile}}/me
Authorization: {{auth_token}}

> {%
  client.test("TC-009: Get profile — 200", function() {
    client.assert(response.status === 200, "FAIL: Phải lấy được profile");
    client.assert(response.body.email === "alice@demo.com", "FAIL: Email mismatch");
  });
%}

###

### TC-010: Cập nhật thông tin cá nhân (200)
PUT {{baseUrl}}{{basePathProfile}}/me
Authorization: {{auth_token}}
Content-Type: application/json

{
  "fullName": "Alice Nguyen (Updated)",
  "avatarUrl": "https://example.com/new-avatar.png",
  "bio": "I love AI and Clean Architecture."
}

> {%
  client.test("TC-010: Update profile — 200", function() {
    client.assert(response.status === 200, "FAIL: Phải cập nhật được profile");
    client.assert(response.body.fullName === "Alice Nguyen (Updated)", "FAIL: Name mismatch");
  });
%}

