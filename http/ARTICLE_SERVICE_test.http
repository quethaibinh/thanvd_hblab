### =============================================================
### ARTICLE SERVICE — Full Integration Test Suite
### Base URL: http://localhost:8080
### =============================================================

@basePathAuth = /api/auth
@basePathArticles = /api/articles

### ─────────────────────────────────────────────────────────────
### SECTION A: AUTHENTICATION (Login & Register)
### ─────────────────────────────────────────────────────────────

### TC-001: Login thành công (200)
# @name login
POST {{baseUrl}}{{basePathAuth}}/login
Content-Type: application/json

{
  "email": "hihi@gmail.com",
  "password": "12345678"
}

> {%
  client.test("TC-001: Login success — 200", function() {
    client.assert(response.status === 200, "FAIL: Expected 200, got " + response.status);
    client.assert(response.body.accessToken !== undefined, "FAIL: accessToken missing in response");
    // Lưu token vào biến global để các request sau sử dụng
    client.global.set("auth_token", "Bearer " + response.body.accessToken);
  });
  client.log("Login thành công! Token đã được lưu.");
%}

###

### TC-002: Login thất bại — sai mật khẩu (401)
POST {{baseUrl}}{{basePathAuth}}/login
Content-Type: application/json

{
  "email": "hihi@gmail.com",
  "password": "wrong_password"
}

> {%
  client.test("TC-002: Login fail — 401", function() {
    client.assert(response.status === 401, "FAIL: Nên trả về 401 khi sai pass");
  });
%}

###

### ─────────────────────────────────────────────────────────────
### SECTION B: ARTICLES (Query & Management)
### ─────────────────────────────────────────────────────────────

### TC-003: Lấy danh sách bài viết (mặc định — 200)
GET {{baseUrl}}{{basePathArticles}}
Authorization: {{auth_token}}

> {%
  client.test("TC-003: Get articles list default — 200", function() {
    client.assert(response.status === 200, "FAIL: Expected 200");
    client.assert(Array.isArray(response.body.content), "FAIL: Body.content phải là một mảng bài viết");
    client.assert(response.body.page === 0, "FAIL: Mặc định trang đầu là 0");
    if (response.body.content.length > 0) {
        client.global.set("first_article_id", response.body.content[0].id);
    }
  });
%}

###

### TC-003.1: Lấy danh sách bài viết có phân trang (page=0, size=5)
GET {{baseUrl}}{{basePathArticles}}?page=0&size=5
Authorization: {{auth_token}}

> {%
  client.test("TC-003.1: Get articles list with pagination — 200", function() {
    client.assert(response.status === 200, "FAIL: Expected 200");
    client.assert(response.body.size === 5, "FAIL: Size mismatch");
    client.assert(response.body.content.length <= 5, "FAIL: Content length > size");
  });
%}

###

### TC-004: Lấy chi tiết một bài viết (200)
# @name get_detail
GET {{baseUrl}}{{basePathArticles}}/{{first_article_id}}
Authorization: {{auth_token}}

> {%
  client.test("TC-004: Get article detail — 200", function() {
    client.assert(response.status === 200, "FAIL: Article ID " + client.global.get("first_article_id") + " not found");
    client.assert(response.body.id === client.global.get("first_article_id"), "FAIL: ID mismatch");
  });
%}

###

### TC-005: Truy cập bài viết không tồn tại (404)
GET {{baseUrl}}{{basePathArticles}}/999999
Authorization: {{auth_token}}

> {%
  client.test("TC-005: Article not found — 404", function() {
    client.assert(response.status === 404, "FAIL: Nên trả về 404 cho ID không tồn tại");
  });
%}
