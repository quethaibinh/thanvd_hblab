### =============================================================
### ARTICLE SERVICE — Comprehensive Integration Test Suite
### Base URL: http://localhost:8080
### =============================================================

@basePathAuth = /api/auth
@basePathArticles = /api/articles
@basePathProfile = /api/profile

### ─────────────────────────────────────────────────────────────
### SECTION A: AUTHENTICATION (Login, Register & Forgot Password)
### ─────────────────────────────────────────────────────────────

### TC-001: Login thành công (200)
# @name login
POST {{baseUrl}}{{basePathAuth}}/login
Content-Type: application/json

{
  "email": "hihi@gmail.com",
  "password": "12345678"
}

> {%
  client.log("Checking TC-001: Login...");
  client.test("TC-001: Login success — 200", function() {
    client.assert(response.status === 200, "FAIL: Expected 200, got " + response.status);
    client.global.set("auth_token", "Bearer " + response.body.accessToken);
    client.global.set("login_email", response.body.email);
  });
%}

###

### TC-002: Đăng ký tài khoản mới (200)
# @name register
POST {{baseUrl}}{{basePathAuth}}/register
Content-Type: application/json

{
  "email": "user_{{$uuid}}@demo.com",
  "password": "password123",
  "fullName": "New User Testing"
}

> {%
  client.log("Checking TC-002: Register...");
  client.test("TC-002: Register success — 200", function() {
    client.assert(response.status === 200, "FAIL: Expected 200, got " + response.status);
  });
%}

###

### TC-003: Quên mật khẩu (200)
# @name forgotPassword
POST {{baseUrl}}{{basePathAuth}}/forgot-password
Content-Type: application/json

{
  "email": "hihi@gmail.com"
}

> {%
  client.log("Checking TC-003: Forgot Password...");
  client.test("TC-003: Forgot password — 200", function() {
    client.assert(response.status === 200, "FAIL: Expected 200, got " + response.status);
  });
%}

###

### TC-004: Login thất bại — sai mật khẩu (401)
# @name loginFail
POST {{baseUrl}}{{basePathAuth}}/login
Content-Type: application/json

{
  "email": "hihi@gmail.com",
  "password": "wrong_password"
}

> {%
  client.log("Checking TC-004: Login Fail (Expected)...");
  client.test("TC-004: Login fail — 401", function() {
    client.assert(response.status === 401, "FAIL: Expected 401, got " + response.status);
  });
%}

###

### ─────────────────────────────────────────────────────────────
### SECTION B: ARTICLES (Query & Management)
### ─────────────────────────────────────────────────────────────

### TC-005: Lấy danh sách bài viết (mặc định — 200)
# @name listArticles
GET {{baseUrl}}{{basePathArticles}}
Authorization: {{auth_token}}

> {%
  client.log("Checking TC-005: List Articles...");
  client.test("TC-005: Get articles list default — 200", function() {
    client.assert(response.status === 200, "FAIL: Expected 200, got " + response.status);
    if (response.body.content && response.body.content.length > 0) {
        client.global.set("first_article_id", response.body.content[0].id);
    }
  });
%}

###

### TC-006: Lấy chi tiết một bài viết (200)
# @name getArticleDetail
GET {{baseUrl}}{{basePathArticles}}/{{first_article_id}}
Authorization: {{auth_token}}

> {%
  client.log("Checking TC-006: Article Detail...");
  client.test("TC-006: Get article detail — 200", function() {
    client.assert(response.status === 200, "FAIL: Expected 200, got " + response.status);
  });
%}

###

