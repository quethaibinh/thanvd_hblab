POST {{baseUrl}}{{basePathArticles}}/{{first_article_id}}/reactions
Authorization: {{auth_token}}
Content-Type: application/json

{
  "reactionType": "LOVE"
}

> {%
  client.log("Checking TC-008: Reaction...");
  client.test("TC-008: React to article — 200", function() {
